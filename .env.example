# Stitch local development configuration.
# Copy to `.env` and edit values for your machine.

# Redis coordination spine for the full system test.
STITCH_REDIS_URL=redis://localhost:6379/0

# W&B Weave tracing.
STITCH_WEAVE_PROJECT=stitch
STITCH_WEAVE_ENABLED=true
STITCH_WEAVE_DISABLED=false
WANDB_API_KEY=

# Optional Slack incoming webhook for P1 notifier work. Not required for P0.
STITCH_SLACK_WEBHOOK_URL=

# Required: extraction uses one Codex SDK thread per source/document.
OPENAI_API_KEY=
STITCH_OPENAI_MODEL=gpt-5.4

# Optional aliases read by underlying libraries/tools.
REDIS_URL=redis://localhost:6379/0
WANDB_PROJECT=stitch
